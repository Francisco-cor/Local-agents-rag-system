{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Agent Station",
  "version": "0.1.0",
  "identifier": "com.local-ai.station",
  "build": {
    "frontendDist": "src/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix src run dev",
    "beforeBuildCommand": "npm --prefix src run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Local AI Agent Station",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}